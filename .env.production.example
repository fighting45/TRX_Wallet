# ============================================
# TRX Wallet Service - Production Configuration
# ============================================

# Application
NODE_ENV=production
PORT=3002

# Laravel Integration
LARAVEL_URL=https://your-production-domain.com
LARAVEL_API_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_KEY

# Auto-start Listener (fetch addresses from Laravel on boot)
AUTO_START_LISTENERS=true

# PostgreSQL Database (Deposit Tracking)
DB_HOST=your-db-host.com
DB_PORT=5432
DB_USERNAME=tron_service
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_DATABASE=tron_wallet
DB_SYNCHRONIZE=false  # CRITICAL: Must be false in production
DB_LOGGING=false

# Master Encryption Password (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_PASSWORD=CHANGE_THIS_TO_64_CHAR_HEX_KEY

# TRON RPC (TronGrid - 500k/day per key)
TRON_RPC_URL=https://api.trongrid.io
TRON_API_TYPE=rest

# TronGrid API Keys (Get from: https://www.trongrid.io)
TRON_API_KEY=your_trongrid_api_key_1
TRON_API_KEY_2=your_trongrid_api_key_2
TRON_API_KEY_3=your_trongrid_api_key_3

# ============================================
# Security Notes:
# ============================================
# 1. LARAVEL_API_SECRET must match WALLET_API_SECRET in Laravel .env
# 2. Never commit this file to git
# 3. Generate new secrets for each environment
# 4. Keep MASTER_PASSWORD secure - losing it means losing access to funds
# ============================================
